{
  "api": {
    "electricitymap_key": "YOUR_API_KEY_HERE",
    "cache_ttl_seconds": 300
  },
  "regions": {
    "IN": {
      "name": "India",
      "flag": "🇮🇳",
      "cloud_function_url": "",
      "enabled": true
    },
    "FI": {
      "name": "Finland",
      "flag": "🇫🇮",
      "cloud_function_url": "",
      "enabled": true
    },
    "DE": {
      "name": "Germany",
      "flag": "🇩🇪",
      "cloud_function_url": "",
      "enabled": true
    },
    "JP": {
      "name": "Japan",
      "flag": "🇯🇵",
      "cloud_function_url": "",
      "enabled": true
    },
    "AU-NSW": {
      "name": "New South Wales, Australia",
      "flag": "🇦🇺",
      "cloud_function_url": "",
      "enabled": true
    },
    "BR-CS": {
      "name": "Central-South Brazil",
      "flag": "🇧🇷",
      "cloud_function_url": "",
      "enabled": true
    }
  },
  "firestore": {
    "collection": "carbon_logs",
    "project_id": "cass-lite"
  },
  "security": {
    "require_authentication": true,
    "service_account": "scheduler-sa@cass-lite.iam.gserviceaccount.com",
    "allowed_origins": ["https://cass-lite-dashboard-262153469989.asia-south1.run.app"],
    "rate_limiting": {
      "enabled": true,
      "max_requests_per_minute": 60
    },
    "logging": {
      "level": "INFO",
      "structured": true,
      "include_request_id": true
    }
  },
  "monitoring": {
    "alerts": {
      "high_error_rate_threshold": 0.05,
      "high_latency_threshold_ms": 5000,
      "cost_alert_threshold_usd": 1.0
    },
    "slo": {
      "window_days": 7,
      "execution_success_rate_min": 0.95,
      "decision_latency_p95_ms": 1500,
      "execution_latency_p95_ms": 7000
    },
    "observability": {
      "structured_logging": true,
      "include_slo_snapshot_in_response": true
    },
    "log_retention_days": 30
  },
  "scheduler": {
    "check_interval_minutes": 15,
    "retry_attempts": 3,
    "retry_delay_seconds": 5,
    "policy": {
      "strategy_mode": "balanced"
    },
    "backtesting": {
      "default_strategies": ["balanced", "carbon_first", "cost_first", "stability_first"],
      "default_report_dir": "reports/backtest",
      "default_limit": 500,
      "simulate_stability": true
    },
    "stability": {
      "lookback_hours": 24,
      "use_weighted_moving_average": true,
      "switch_threshold_percent": 12,
      "min_hold_hours": 24,
      "weights": {
        "carbon": 0.6,
        "latency": 0.25,
        "cost": 0.15
      }
    },
    "region_latency_ms": {
      "IN": 10,
      "FI": 180,
      "DE": 150,
      "JP": 90,
      "AU-NSW": 140,
      "BR-CS": 350
    },
    "region_cost_usd": {
      "IN": 0.0476,
      "FI": 0.057,
      "DE": 0.0475,
      "JP": 0.056,
      "AU-NSW": 0.0595,
      "BR-CS": 0.045
    }
  }
}
